# Genome configuration — copy to .env and fill in.
# Most secrets are already present in ~/homelab/.env on iMac. The deploy
# script (deploy/bootstrap.sh) symlinks them through.

# --- Brand ---
GENOME_PUBLIC_NAME=Genome
GENOME_TAGLINE=Self-hosted music discovery

# --- Postgres ---
DATABASE_URL=postgres://genome:genome@postgres:5432/genome
POSTGRES_USER=genome
POSTGRES_PASSWORD=genome-local-dev
POSTGRES_DB=genome

# --- Engine ---
GENOME_ENGINE_URL=http://genome-engine:8001
GENOME_ENGINE_INTERNAL_URL=http://localhost:8001  # for SSR fetches inside web container

# --- Discovery sources ---
LASTFM_API_KEY=
LASTFM_API_SECRET=
LISTENBRAINZ_USER=tyler702702
LISTENBRAINZ_TOKEN=
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
MUSICBRAINZ_USER_AGENT=Genome/1.0 (genome.tyflix.net)

# --- Library integration ---
LIDARR_URL=http://host.docker.internal:8686
LIDARR_API_KEY=
PLAYLIST_DL_URL=http://host.docker.internal:8800
NAVIDROME_URL=http://host.docker.internal:4533
PLEX_URL=http://host.docker.internal:32400
PLEX_TOKEN=

# --- Tuning defaults (overridable per-station) ---
GENOME_DEFAULT_FEATURE_WEIGHT=0.35
GENOME_DEFAULT_TAG_WEIGHT=0.25
GENOME_DEFAULT_LASTFM_WEIGHT=0.25
GENOME_DEFAULT_LISTENBRAINZ_WEIGHT=0.15
GENOME_EXPLORATION_RATIO=0.20
GENOME_CANDIDATE_POOL_SIZE=200

# --- yt-dlp ---
YTDLP_CACHE_TTL_SECONDS=18000  # 5h, expires before YT signature TTL
YTDLP_CONCURRENT_RESOLVES=4

# --- Logging ---
LOG_LEVEL=info
